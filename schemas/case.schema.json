{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://laibench.laudos.ai/schemas/case.schema.json",
  "title": "LAIBench case",
  "description": "A single benchmark case: an exam descriptor plus concise findings, with optional public-safe gold data. Mirrors the BenchCase type in src/types.ts. Public cases MUST set synthetic: true and contain no patient-identifying information.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "exam", "findings"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "label": { "type": "string" },
    "synthetic": { "type": "boolean", "description": "Must be true for cases published in this repository." },
    "exam": { "type": "string", "minLength": 1, "description": "Short modality + anatomy descriptor." },
    "findings": { "type": "string", "minLength": 1, "description": "Concise free-text findings in the case locale." },
    "locale": { "type": "string", "enum": ["pt-BR", "en-US"] },
    "tags": { "type": "array", "items": { "type": "string" } },
    "schemaVersion": { "type": "string" },
    "goldFindings": { "type": "array", "items": { "$ref": "#/$defs/goldFinding" } },
    "referenceReport": { "type": "string", "description": "Optional gold HTML report for reference." },
    "criticalFindings": { "type": "array", "items": { "type": "string" }, "description": "Clinically decisive findings that must be preserved." },
    "guidelineExpectations": { "type": "array", "items": { "$ref": "#/$defs/guidelineExpectation" } },
    "retrievalGold": { "type": "array", "items": { "$ref": "#/$defs/retrievalRelevance" } },
    "patientContext": { "$ref": "#/$defs/patientContext" },
    "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] }
  },
  "$defs": {
    "goldFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding", "severity"],
      "properties": {
        "finding": { "type": "string", "minLength": 1 },
        "location": { "type": "string" },
        "laterality": { "type": "string", "enum": ["right", "left", "bilateral"] },
        "severity": { "type": "string", "enum": ["critical", "major", "minor", "incidental"] },
        "measurements": { "type": "array", "items": { "type": "string" } },
        "negated": { "type": "boolean" }
      }
    },
    "guidelineExpectation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "guidelineId": { "type": "string", "description": "e.g. fleischner, birads, tirads, lirads, pirads, bosniak, lungrads" },
        "expectedClassification": { "type": "string" },
        "recommendationRequired": { "type": "boolean" },
        "expectedRecommendation": { "type": "string" }
      }
    },
    "retrievalRelevance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["documentId", "relevance"],
      "properties": {
        "documentId": { "type": "string" },
        "relevance": { "type": "integer", "minimum": 0, "maximum": 3 }
      }
    },
    "patientContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sex": { "type": "string" },
        "age": { "type": "number" },
        "indication": { "type": "string" }
      }
    }
  }
}
